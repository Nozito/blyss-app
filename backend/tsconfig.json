{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["server.ts", "lib/**/*.ts", "middleware/**/*.ts", "routes/**/*.ts", "cron/**/*.ts", "services/**/*.ts", "__tests__/**/*.ts", "vitest.config.ts"]
}