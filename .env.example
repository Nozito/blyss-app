# ============================================================
# .env.example — BlyssApp environment variables
# Copy to backend/.env.dev (dev) or backend/.env.prod (prod)
# and fill in real values. NEVER commit real secrets.
# ============================================================

# ── Backend ──────────────────────────────────────────────────
#
# DATABASE_URL — deux formats Supabase :
#   Direct (IPv6 seulement sur free plan) :
#     postgresql://postgres:[pwd]@db.[ref].supabase.co:5432/postgres
#   Pooler session mode (IPv4, recommandé — activer dans Supabase dashboard) :
#     postgresql://postgres.[ref]:[pwd]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
#   ⚠️  Ne pas utiliser le pooler transaction (port 6543) — incompatible avec les transactions pg
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Token Supabase Management API — pour scripts/db.mjs (migrations, seed)
# Générer : https://supabase.com/dashboard/account/tokens
# En local, supabase login suffit (keychain macOS) — cette var n'est obligatoire qu'en CI
SUPABASE_ACCESS_TOKEN=[sbp_...]
JWT_SECRET=[min-32-chars — generate: openssl rand -base64 48]
STRIPE_SECRET_KEY=sk_test_[PLACEHOLDER]
STRIPE_WEBHOOK_SECRET=whsec_[PLACEHOLDER]
REVENUECAT_WEBHOOK_SECRET=[PLACEHOLDER]

# OBLIGATOIRE — AES-256-GCM key for IBAN encryption
# Generate: openssl rand -hex 32
# NEVER lose this key — loss = permanent decryption failure
IBAN_ENC_KEY=[64-hex-chars]

# OBLIGATOIRE en prod — comma-separated allowed origins
# No fallback in production (server will warn and allow only localhost if missing)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

NODE_ENV=development
PORT=3001

# URL du frontend — utilisée pour les redirects OAuth Instagram
FRONTEND_URL=http://localhost:5173

# Instagram OAuth (optionnel si feature non activée)
INSTAGRAM_APP_ID=[PLACEHOLDER]
INSTAGRAM_APP_SECRET=[PLACEHOLDER]
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/instagram/callback
# Generate: openssl rand -hex 32
INSTAGRAM_TOKEN_KEY=[64-hex-chars]
# Generate: openssl rand -base64 32
INSTAGRAM_STATE_SECRET=[PLACEHOLDER]

# ── Web Push / VAPID ──────────────────────────────────────────
# Générer : cd backend && npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=[PLACEHOLDER]
VAPID_PRIVATE_KEY=[PLACEHOLDER]
VAPID_EMAIL=contact@blyssapp.fr

# ── Monitoring — optionnel ────────────────────────────────────
# Sentry backend (create project at sentry.io → Node.js)
SENTRY_DSN=[PLACEHOLDER — e.g. https://xxx@oyyy.ingest.sentry.io/zzz]
SENTRY_ENVIRONMENT=development

# Alert webhook (Slack or Discord incoming webhook URL)
ALERT_WEBHOOK_URL=[PLACEHOLDER — https://hooks.slack.com/... or https://discord.com/api/webhooks/...]

# ── Frontend (Vite) ──────────────────────────────────────────
# URL de l'API backend (sans /api, sans slash final)
VITE_API_URL=http://localhost:3001

# OBLIGATOIRE en prod — WebSocket URL (wss:// en prod, ws:// en dev)
# Ne pas laisser dériver automatiquement depuis VITE_API_URL
VITE_WS_URL=ws://localhost:3001

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_[PLACEHOLDER]
VITE_REVENUECAT_API_KEY=[PLACEHOLDER]

# Sentry frontend (same Sentry project, DSN is public — different from backend DSN)
VITE_SENTRY_DSN=[PLACEHOLDER — same sentry project, public DSN]
VITE_SENTRY_ENVIRONMENT=development

# ── Playwright E2E ───────────────────────────────────────────
BASE_URL=http://localhost:8080
API_URL=http://localhost:3001
TEST_ADMIN_EMAIL=admin@blyss.test
TEST_ADMIN_PASSWORD=[PLACEHOLDER]
